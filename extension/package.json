{
  "name": "@kindoo/extension",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "description": "Stake Building Access Chrome extension. Surfaces pending requests from SBA in a Chrome side panel on Kindoo so a Kindoo Manager can work the queue alongside the Kindoo admin UI.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:unit": "vitest run",
    "lint": "prettier --check src",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@kindoo/shared": "workspace:*",
    "firebase": "^12.12.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0",
    "@types/chrome": "^0.0.300",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
