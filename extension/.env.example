# Firebase web SDK config — Vite exposes only `VITE_*` vars to extension code.
#
# Copy this file to one of these per-mode targets (all gitignored):
#   - extension/.env.staging      (loaded by `vite build --mode staging`)
#   - extension/.env.production   (loaded by `vite build`, default mode)
# Values come from the Firebase console:
#   Console → Project settings → General → Your apps → Web → Config.
#
# The Google OAuth client ID for chrome.identity is separate from the
# Firebase web app config — it's a Web application OAuth 2.0 client in
# Google Cloud Console (OAuth 2.0 Client IDs). Set it in
# VITE_GOOGLE_OAUTH_CLIENT_ID; @crxjs substitutes it into manifest.json
# at build time.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_GOOGLE_OAUTH_CLIENT_ID=
