# Firebase web SDK config — Vite exposes only `VITE_*` vars to extension code.
#
# Copy this file to one of these per-mode targets (all gitignored):
#   - extension/.env.staging      (loaded by `vite build --mode staging`)
#   - extension/.env.production   (loaded by `vite build`, default mode)
# Values come from the Firebase console:
#   Console → Project settings → General → Your apps → Web → Config.
#
# The Google OAuth client ID for chrome.identity is separate from the
# Firebase web app config — it's a "Chrome app" OAuth 2.0 client in
# Google Cloud Console (one per extension ID, so one per env).
#
# See extension/CLAUDE.md "Per-env setup" for the full keypair / GCP
# OAuth client / Chrome unpacked-load walkthrough.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_GOOGLE_OAUTH_CLIENT_ID=

# Per-env identity. Both are picked up by src/manifest.config.ts at build time.
#
# VITE_EXTENSION_KEY — base64-encoded DER public key. Pins the Chrome
#   extension ID so the GCP "Chrome app" OAuth client (which is bound
#   to a single extension ID) keeps working across rebuilds. Generate:
#     openssl genrsa -out keys/staging.pem 2048
#     openssl rsa -in keys/staging.pem -pubout -outform DER | base64 | tr -d '\n'
#   Compute the resulting extension ID via:
#     pnpm --filter @kindoo/extension ext-id --key <base64>
#   Keep keys/*.pem private (gitignored). The base64 public key here
#   is public-by-design — it literally ships as the manifest `key`
#   field — but the .env.* files themselves stay gitignored to avoid
#   leaking the OAuth client ID + Firebase config bundle.
#
# VITE_EXTENSION_NAME — manifest `name` Chrome shows in the toolbar
#   tooltip + chrome://extensions list. Pick a name that distinguishes
#   staging from production at a glance.
#     prod:    Stake Building Access — Kindoo Helper
#     staging: SBA Helper (Staging)

VITE_EXTENSION_KEY=
VITE_EXTENSION_NAME=
