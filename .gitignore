# Node
node_modules/
npm-debug.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Env
.env
.env.local
.env.*.local
.env.production
.env.*.production
.env.staging
.env.*.staging
functions/.env*

# Claude Code local state (subagent definitions under .claude/agents/ ARE committed)
.claude/worktrees/
.claude/scheduled_tasks.lock
.claude/settings.local.json

# Firebase + monorepo
# Web SPA build output
apps/*/dist/
# Cloud Functions build output (firebase-functions emits to lib/; some setups use dist/)
functions/lib/
functions/dist/
# packages/shared/ build output (TS project references emit to dist/)
packages/*/dist/
# Chrome extension build output (Vite + @crxjs emits to dist/)
extension/dist/
# firestore/ tsconfig outDir (typecheck-only; tests run via vitest)
firestore/.tsbuild/
# functions/ tests tsconfig outDir (typecheck-only; tests run via vitest)
functions/.tsbuild-tests/
# TypeScript incremental build cache — local-only, regenerated by `tsc -b`
**/*.tsbuildinfo
**/.tsbuildinfo
# Generated build-version stamps — seeded by infra/scripts/ensure-version-gen.js
# on `pnpm install`, overwritten by infra/scripts/stamp-version.js on deploy.
apps/web/src/version.gen.ts
functions/src/version.gen.ts
# Firebase CLI local state (emulator data, hosting cache, etc.)
.firebase/
firebase-debug.log
firebase-debug.*.log
# Operator-local Firebase project overrides — never commit
.firebaserc.local
# Vitest coverage output
coverage/
# Playwright artifacts
playwright-report/
test-results/
# pnpm-lock.yaml IS committed (workspace lockfile is the source of truth);
# do NOT add it here.
