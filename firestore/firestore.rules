rules_version = '2';

// Phase 1 stub — locked down. Real rules land in Phase 3 per
// docs/firebase-schema.md §6, where the deny-by-default with
// explicit allows by collection gets implemented and tested.
//
// Until then, the only way data gets into Firestore is via the
// Admin SDK (Cloud Functions, deploy-time seed scripts), which
// bypasses rules. This is intentional: it means a misconfigured
// client cannot write anything during Phases 1–2 even by accident.

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
