rules_version = '2';

// Firestore Security Rules — full per-collection allow/deny matrix per
// `docs/firebase-schema.md` §6.
//
// Conventions:
//
//   - Helpers at top: `isAuthed`, `authedCanonical`, `isManager`,
//     `isStakeMember`, `bishopricWardOf`, `isAnyMember`,
//     `isPlatformSuperadmin`, `lastActorMatchesAuth`. Defined once,
//     reused throughout.
//
//   - `lastActor` integrity check is the primary defense: every
//     client write must carry `lastActor.{email, canonical}` matching
//     the auth token's typed email + custom-claim canonical. This is
//     what gives the audit trigger a trustworthy `actor_email`.
//
//   - `getAfter()` is used in exactly one place — `seats.create`'s
//     `tiedToRequestCompletion` invariant — so a seat creation
//     proves it is the resolution of a pending request transitioning
//     to `complete` in the same write.
//
//   - Split-ownership on `access`: `importer_callings` is
//     server-only (Importer via Admin SDK bypasses rules). Manager
//     updates must leave it byte-equal to the prior value. Manual
//     side (`manual_grants`) is the manager's lane.
//
//   - Cross-stake denial is automatic: `isAnyMember(stakeId)` returns
//     false when the user has no claim block for `stakeId`, so a
//     read against another stake fails the parent-doc rule and never
//     reaches the subcollection rules.
//
//   - Admin SDK writes (importer, expiry, claim sync, audit trigger,
//     remove-seat trigger) bypass rules entirely. The Cloud Functions
//     code carries the discipline.
//
//   - Bootstrap-wizard escape hatch: `isBootstrapAdmin(stakeId)` lets
//     the designated `stake.bootstrap_admin_email` user write to the
//     wizard-managed collections (stakes/{sid}, kindooManagers, wards,
//     buildings) WHILE `setup_complete == false`. Once the wizard
//     flips that flag to true, the gate goes silent — by then the
//     `syncManagersClaims` trigger has minted the bootstrap admin a
//     real manager claim from their auto-added kindooManagers doc, so
//     `isManager(stakeId)` takes over. This breaks the chicken-and-egg
//     where the very first wizard write (the bootstrap admin's own
//     kindooManagers doc) had nothing else to authorise it.
//
//     Operator pre-step: the stake doc must exist with
//     `setup_complete=false` and `bootstrap_admin_email=<typed email>`
//     BEFORE the bootstrap admin signs in for the first time. See
//     `infra/runbooks/provision-firebase-projects.md` for the seed
//     instructions.
//
//   - Setup-in-progress read gate: `isSetupInProgressReadable(stakeId)`
//     lets ANY authed user read the parent stake doc while
//     `setup_complete == false`. Required by the SPA's setup-complete
//     gate (per `docs/spec.md` §10): a non-admin signing in during bootstrap
//     must land on SetupInProgress (not NotAuthorized), and the gate
//     can only know "we're in setup" by reading the parent doc.
//     Once the wizard completes, this gate goes silent and standard
//     `isAnyMember` membership reads take over.

service cloud.firestore {
  match /databases/{database}/documents {

    // ===== Helpers =====

    function isAuthed() {
      return request.auth != null;
    }

    // Trustworthy: `canonical` is set by the sync triggers as a custom
    // claim (`syncManagersClaims` / `syncAccessClaims` /
    // `syncSuperadminClaims`). Comparing against this lets us key off
    // the canonical email without a per-call userIndex lookup.
    function authedCanonical() {
      return request.auth.token.canonical;
    }

    function isManager(stakeId) {
      return isAuthed()
        && 'stakes' in request.auth.token
        && stakeId in request.auth.token.stakes
        && request.auth.token.stakes[stakeId].manager == true;
    }

    function isStakeMember(stakeId) {
      return isAuthed()
        && 'stakes' in request.auth.token
        && stakeId in request.auth.token.stakes
        && request.auth.token.stakes[stakeId].stake == true;
    }

    // Returns the ward_code list for which the user has bishopric
    // visibility under `stakeId`. Empty list if not a member of that
    // stake.
    function bishopricWardOf(stakeId) {
      return isAuthed()
        && 'stakes' in request.auth.token
        && stakeId in request.auth.token.stakes
          ? request.auth.token.stakes[stakeId].wards
          : [];
    }

    // Any member of the stake — manager OR stake-scope member OR any
    // bishopric-ward member. Used to gate parent-stake-doc reads and
    // wards/buildings reads.
    function isAnyMember(stakeId) {
      return isManager(stakeId)
        || isStakeMember(stakeId)
        || bishopricWardOf(stakeId).size() > 0;
    }

    function isPlatformSuperadmin() {
      return isAuthed() && request.auth.token.isPlatformSuperadmin == true;
    }

    // Bootstrap-admin escape hatch — see file header. The token email
    // is the typed form (Firebase puts the verified-email string on
    // `request.auth.token.email`); we compare against the typed email
    // recorded on the stake doc by the operator's pre-seed. The
    // `setup_complete == false` clause makes this strictly time-bounded
    // so the moment the wizard flips that flag, this gate stops applying.
    //
    // The `get()` short-circuits if the stake doc doesn't exist (rule
    // returns false rather than erroring) — operator seed is mandatory
    // before the bootstrap admin signs in.
    function isBootstrapAdmin(stakeId) {
      let stakePath = /databases/$(database)/documents/stakes/$(stakeId);
      return isAuthed()
        && exists(stakePath)
        && get(stakePath).data.setup_complete == false
        && get(stakePath).data.bootstrap_admin_email == request.auth.token.email;
    }

    // Setup-in-progress escape hatch — required by the SPA's
    // setup-complete gate (per `docs/spec.md` §10): when `setup_complete == false`, any
    // authed user must be able to read the parent stake doc so the
    // gate can route them to SetupInProgress (instead of NotAuthorized
    // or a blank screen). Once the wizard flips `setup_complete` to
    // true, this gate goes silent and the standard `isAnyMember` rule
    // takes over.
    //
    // The disclosure surface is small: the parent stake doc carries
    // `stake_name`, `bootstrap_admin_email` (already the operator's
    // typed email), config knobs (`callings_sheet_id`, schedule
    // hours, `stake_seat_cap`), and bookkeeping fields. None of these
    // are sensitive — `bootstrap_admin_email` is what the SetupInProgress
    // page renders to the non-admin so they know who to contact.
    function isSetupInProgressReadable(stakeId) {
      let stakePath = /databases/$(database)/documents/stakes/$(stakeId);
      return isAuthed()
        && exists(stakePath)
        && get(stakePath).data.setup_complete == false;
    }

    // The `lastActor` integrity check — every client write must
    // declare `lastActor.{email, canonical}` matching the auth token.
    // Server-side (Admin SDK) writes use synthetic actors
    // (`'Importer'` / `'ExpiryTrigger'`) and bypass this check by
    // bypassing rules entirely.
    function lastActorMatchesAuth(data) {
      return data.lastActor.canonical == authedCanonical()
        && data.lastActor.email == request.auth.token.email;
    }

    // ===== Top-level collections =====

    // userIndex/{canonical} — written by `onAuthUserCreate` (Admin
    // SDK bypass); read by the user themselves so the SPA can confirm
    // the bridge entry exists with the expected uid.
    //
    // Self-update is permitted ONLY for `fcmTokens` + `notificationPrefs`
    // + `lastActor` (push-subscribe write surface). Create/delete remain
    // server-only. The `lastActor` integrity check stamps the writer so
    // any audit-trail tooling sees who toggled push state.
    match /userIndex/{memberCanonical} {
      allow read: if isAuthed() && resource.data.uid == request.auth.uid;
      allow update: if isAuthed()
        && resource.data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['fcmTokens', 'notificationPrefs', 'lastActor'])
        && lastActorMatchesAuth(request.resource.data);
      allow create, delete: if false;
    }

    // platformSuperadmins — allow-list for the cross-stake superadmin
    // role. Read by superadmins (so a superadmin can list peers);
    // write forbidden (managed via Firestore console only — see
    // `firebase-schema.md` §3.2).
    match /platformSuperadmins/{canonicalEmail} {
      allow read: if isPlatformSuperadmin();
      allow write: if false;
    }

    // platformAuditLog — cross-stake audit trail for stake creation
    // and superadmin-membership changes. Read by superadmins; writes
    // server-only (the `createStake` callable + the superadmin
    // sync triggers fan rows here via Admin SDK).
    match /platformAuditLog/{auditId} {
      allow read: if isPlatformSuperadmin();
      allow write: if false;
    }

    // ===== Per-stake collections =====

    match /stakes/{stakeId} {

      // Parent stake doc — Config-tab-equivalent fields. Read by any
      // member of the stake (the SPA's bootstrap response includes
      // stake metadata for every signed-in member). Updates by
      // managers only, enforcing the lastActor integrity check. Create
      // is superadmin-only via the `createStake` callable; delete
      // forbidden everywhere.
      //
      // Bootstrap-admin gate: while `setup_complete == false`, the
      // designated bootstrap admin can read the stake doc (the wizard
      // needs to render current values) and update it (Step 1 fields
      // and the final `setup_complete=true` flip). The flip itself
      // works because `isBootstrapAdmin` evaluates the pre-write state
      // — `setup_complete` is still false when the rule runs.
      //
      // Setup-in-progress read gate: while `setup_complete == false`,
      // ANY authed user can read the parent stake doc so the SPA's
      // setup-complete gate can route them to SetupInProgress. This is
      // a narrow read-only loosening tied to the same time-bound
      // condition as `isBootstrapAdmin`; once setup completes, the
      // standard `isAnyMember` rule takes over again.
      allow read: if isAnyMember(stakeId) || isBootstrapAdmin(stakeId)
        || isSetupInProgressReadable(stakeId);
      allow create: if isPlatformSuperadmin();
      allow update: if (isManager(stakeId) || isBootstrapAdmin(stakeId))
        && lastActorMatchesAuth(request.resource.data);
      allow delete: if false;

      // ----- Wards -----
      // Any member of the stake can read the ward list (Roster UI
      // needs them for utilization rendering). Only managers can
      // mutate; the integrity check stamps the writing manager.
      // Bootstrap admin can read + write while `setup_complete=false`
      // so the wizard's Step 3 (≥1 ward) can land before the manager
      // claim is minted.
      //
      // Create + update carry the `lastActorMatchesAuth` integrity
      // check; delete cannot (no `request.resource.data` on delete) and
      // is gated only by the role predicate. Same split applied to
      // buildings + kindooManagers below.
      match /wards/{wardCode} {
        allow read: if isAnyMember(stakeId) || isBootstrapAdmin(stakeId);
        allow create, update: if (isManager(stakeId) || isBootstrapAdmin(stakeId))
          && lastActorMatchesAuth(request.resource.data);
        allow delete: if isManager(stakeId) || isBootstrapAdmin(stakeId);
      }

      // ----- Buildings -----
      // Same shape as wards — any member can read; only managers
      // can mutate. Bootstrap-admin gate matches wards: the wizard's
      // Step 2 (≥1 building) writes here.
      match /buildings/{buildingId} {
        allow read: if isAnyMember(stakeId) || isBootstrapAdmin(stakeId);
        allow create, update: if (isManager(stakeId) || isBootstrapAdmin(stakeId))
          && lastActorMatchesAuth(request.resource.data);
        allow delete: if isManager(stakeId) || isBootstrapAdmin(stakeId);
      }

      // ----- KindooManagers -----
      // Manager allow-list. Manager-only read so non-managers can't
      // enumerate peers; manager-only write. The bootstrap-admin gate
      // unblocks the chicken-and-egg: the wizard's first action is
      // adding the bootstrap admin to this collection, which fires
      // `syncManagersClaims` and mints the manager claim. Without the
      // gate, that very first write would be denied because the
      // bootstrap admin doesn't yet hold a manager claim.
      match /kindooManagers/{memberCanonical} {
        allow read: if isManager(stakeId) || isBootstrapAdmin(stakeId);
        allow create, update: if (isManager(stakeId) || isBootstrapAdmin(stakeId))
          && lastActorMatchesAuth(request.resource.data);
        allow delete: if isManager(stakeId) || isBootstrapAdmin(stakeId);
      }

      // ----- Access (split-ownership) -----
      // The most subtle rule block in this file. The doc has two
      // top-level maps with different write authorities:
      //
      //   - `importer_callings` — server-only (the weekly Importer
      //     wholesale-replaces this map per scope via Admin SDK).
      //     Rules forbid client mutation by requiring it to be
      //     byte-equal to the prior value on every client update.
      //
      //   - `manual_grants` — manager-only client-writable. The
      //     `affectedKeys()` allowlist below enumerates exactly the
      //     fields a manager update may touch.
      //
      // Manager-only read covers `access` because non-managers
      // shouldn't be able to enumerate the role grants.
      match /access/{memberCanonical} {
        allow read: if isManager(stakeId);

        // Manager creates a manual-only access doc — no importer
        // rows yet (the importer would have created the doc itself
        // if there were any). At least one manual_grants entry is
        // required so we don't create empty docs that would
        // immediately satisfy the delete predicate.
        allow create: if isManager(stakeId)
          && memberCanonical == request.resource.data.member_canonical
          && request.resource.data.importer_callings == {}
          && request.resource.data.manual_grants.size() > 0
          && lastActorMatchesAuth(request.resource.data);

        // Manager edits manual_grants only — `importer_callings`
        // is immutable from clients, and only the manual side +
        // bookkeeping fields are in the affected-keys allowlist.
        allow update: if isManager(stakeId)
          && request.resource.data.member_canonical == resource.data.member_canonical
          && request.resource.data.importer_callings == resource.data.importer_callings
          && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['manual_grants', 'last_modified_by', 'last_modified_at', 'lastActor'])
          && lastActorMatchesAuth(request.resource.data);

        // Manager deletes a now-empty access doc. The Importer
        // empties `importer_callings` on a wholesale-replace if the
        // user no longer has any qualifying callings; the manager
        // empties `manual_grants` by removing its last entry.
        // The delete only fires when both are empty so the doc-
        // existence invariant ("exists iff some grant exists") is
        // preserved.
        allow delete: if isManager(stakeId)
          && resource.data.importer_callings == {}
          && resource.data.manual_grants == {};
      }

      // ----- Seats -----
      // Reads: managers see all; stake members see every roster in
      // the stake (stake-level access grants cross-ward oversight —
      // the Ward Rosters page lists every ward, and a stake user
      // clicking any of them must succeed); bishopric members see
      // seats whose scope is one of their assigned wards.
      //
      // Creates: only via request completion (the
      // `tiedToRequestCompletion` cross-doc invariant below verifies
      // a request flips pending → complete in the same write). Auto
      // seats are written by the Importer via Admin SDK and bypass
      // rules entirely; client-create only allows manual/temp.
      //
      // Updates: managers can edit a small allowlist of fields on
      // existing manual/temp seats. Primary scope/type/canonical are
      // immutable post-creation (a re-scope is a new request).
      //
      // Deletes: managers can delete a manual/temp seat with no
      // duplicate_grants. Remove-request completions go through a
      // Cloud Function (Admin SDK bypass) instead, since client
      // delete rules can't read request.resource.data.
      match /seats/{memberCanonical} {
        allow read: if isManager(stakeId)
          || isStakeMember(stakeId)
          || (resource.data.scope in bishopricWardOf(stakeId));

        allow create: if isManager(stakeId)
          && memberCanonical == request.resource.data.member_canonical
          && request.resource.data.type in ['manual', 'temp']
          && request.resource.data.duplicate_grants.size() == 0
          && request.resource.data.callings.size() == 0
          && lastActorMatchesAuth(request.resource.data)
          && tiedToRequestCompletion(stakeId,
                                     request.resource.data.granted_by_request,
                                     request.resource.data.scope,
                                     memberCanonical,
                                     request.resource.data.type);

        allow update: if isManager(stakeId)
          && resource.data.type in ['manual', 'temp']
          && request.resource.data.member_canonical == resource.data.member_canonical
          && request.resource.data.scope == resource.data.scope
          && request.resource.data.type == resource.data.type
          && lastActorMatchesAuth(request.resource.data)
          && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['member_name', 'reason', 'building_names', 'start_date', 'end_date',
                       'duplicate_grants', 'last_modified_by', 'last_modified_at', 'lastActor']);

        allow delete: if isManager(stakeId)
          && resource.data.type in ['manual', 'temp']
          && resource.data.duplicate_grants.size() == 0;
      }

      // The cross-doc invariant that gates seat creation: a manual /
      // temp seat may only be created when the request that justifies
      // it transitions from pending → complete in the same write. We
      // use `getAfter()` (the after-this-write view) to read the
      // request as it will look once the client's transaction commits.
      // `getAfter()` is used here and ONLY here — every other rule
      // is local to its own document.
      function tiedToRequestCompletion(sid, requestId, expectedScope, expectedMember, expectedSeatType) {
        let reqBefore = get(/databases/$(database)/documents/stakes/$(sid)/requests/$(requestId));
        let reqAfter  = getAfter(/databases/$(database)/documents/stakes/$(sid)/requests/$(requestId));
        return reqBefore.data.status == 'pending'
          && reqAfter.data.status == 'complete'
          && reqAfter.data.scope == expectedScope
          && reqAfter.data.member_canonical == expectedMember
          && (
            (expectedSeatType == 'manual' && reqAfter.data.type == 'add_manual')
            || (expectedSeatType == 'temp' && reqAfter.data.type == 'add_temp')
          );
      }

      // ----- Requests -----
      // Reads: managers see all; the original requester sees their
      // own; stake-scope members see every request in the stake
      // (stake-level access grants cross-ward oversight — the Ward
      // Rosters page also surfaces pending requests per ward, and a
      // stake user clicking any ward must succeed); ward-scope is
      // visible to bishopric members of that ward.
      //
      // Creates (Submit): only `pending` is a legal starting status.
      // The requester_canonical must match the auth token's canonical
      // claim. Add-types require member_name; stake-scope add-types
      // require at least one building selection. Scope must match
      // the requester's role:
      //   - stake-scope: stake membership
      //   - ward-scope: that ward in the bishopric list
      // Manager status alone does NOT grant creation rights (B-3 /
      // T-36) — a pure-manager user with no stake / no ward claim
      // has no submit surface. A manager who also holds `stake: true`
      // or a bishopric ward inherits creation rights through those
      // branches, like any other user. The self-approval invariant
      // (spec §6, F12 invariant 7) still works: a manager who holds
      // the role for the scope can submit then complete their own
      // request.
      //
      // Updates: pending → terminal only. Cancellation is requester-
      // only; complete / reject are manager-only. Reject requires a
      // non-empty rejection_reason.
      //
      // Deletes: never.
      match /requests/{requestId} {
        allow read: if isAuthed() && (
          isManager(stakeId)
          || resource.data.requester_canonical == authedCanonical()
          || isStakeMember(stakeId)
          || (resource.data.scope in bishopricWardOf(stakeId))
        );

        // `urgent` typed as bool when present (missing → treated as
        // false on read); rules forbid garbage like `urgent: 17` /
        // `urgent: "yes"`. Immutable post-submit: the update predicate
        // below uses an explicit field allowlist for each terminal
        // transition (cancel/complete/reject) and `urgent` is not in
        // any of those sets, so it cannot be modified.
        //
        // `add_temp` carries ISO `YYYY-MM-DD` start_date + end_date
        // with `start_date <= end_date`. The manager queue's
        // sectioning (Outstanding vs Future) depends on start_date
        // being present and well-formed for every add_temp.
        allow create: if isAuthed()
          && request.resource.data.status == 'pending'
          && request.resource.data.requester_canonical == authedCanonical()
          && request.resource.data.requested_at == request.time
          && lastActorMatchesAuth(request.resource.data)
          && (!('urgent' in request.resource.data)
              || request.resource.data.urgent is bool)
          && (request.resource.data.type == 'remove'
              || request.resource.data.member_name.size() > 0)
          && (request.resource.data.type == 'remove'
              || request.resource.data.scope != 'stake'
              || request.resource.data.building_names.size() > 0)
          && (request.resource.data.type != 'add_temp'
              || (
                   'start_date' in request.resource.data
                && 'end_date' in request.resource.data
                && request.resource.data.start_date is string
                && request.resource.data.end_date is string
                && request.resource.data.start_date.matches('^\\d{4}-\\d{2}-\\d{2}$')
                && request.resource.data.end_date.matches('^\\d{4}-\\d{2}-\\d{2}$')
                && request.resource.data.start_date <= request.resource.data.end_date
              ))
          // Role-for-scope gate (defense-in-depth complement to the
          // SPA's `allowedScopesFor` filter, B-3 / T-36). The submitter
          // must hold the role matching the scope they are writing:
          //   - `scope == 'stake'`  → caller holds `stake: true`
          //   - `scope == <ward>`   → caller's `wards` includes that code
          // Manager status alone does NOT grant creation rights — a
          // pure-manager user with no stake / no ward claim has no
          // submit surface. A manager who also holds `stake: true` or a
          // bishopric ward inherits creation rights through those
          // branches, same as any other user. This matches `scopeOptions.ts`
          // on the SPA so a hand-crafted POST cannot bypass the dropdown
          // filter.
          && (
               (request.resource.data.scope == 'stake' && isStakeMember(stakeId))
            || (request.resource.data.scope in bishopricWardOf(stakeId))
          );

        // `urgent` is requester-set on submit and immutable afterward.
        // Each transition's affectedKeys allowlist below excludes it,
        // and we additionally require the field's value (or absence)
        // be byte-equal across the write so a client cannot toggle it
        // even by smuggling it into an otherwise-allowed update.
        allow update: if resource.data.status == 'pending'
          && lastActorMatchesAuth(request.resource.data)
          && (('urgent' in resource.data) == ('urgent' in request.resource.data))
          && (!('urgent' in resource.data)
              || request.resource.data.urgent == resource.data.urgent)
          && (
            // Cancel — only the original requester
            (request.resource.data.status == 'cancelled'
             && resource.data.requester_canonical == authedCanonical()
             && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['status', 'lastActor']))
            ||
            // Complete — only managers (self-approval is allowed; rules
            // do not require requester != completer per F12 invariant 7)
            (request.resource.data.status == 'complete'
             && isManager(stakeId)
             && request.resource.data.completer_canonical == authedCanonical()
             && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['status', 'completer_email', 'completer_canonical',
                          'completed_at', 'completion_note', 'lastActor']))
            ||
            // Reject — only managers, with non-empty reason
            (request.resource.data.status == 'rejected'
             && isManager(stakeId)
             && request.resource.data.rejection_reason.size() > 0
             && request.resource.data.completer_canonical == authedCanonical()
             && request.resource.data.diff(resource.data).affectedKeys()
                .hasOnly(['status', 'completer_email', 'completer_canonical',
                          'completed_at', 'rejection_reason', 'lastActor']))
          );

        allow delete: if false;
      }

      // ----- Calling templates -----
      // Manager-only on both reads and writes. Templates seed the
      // importer's mapping from calling-name → app-access; they're
      // configuration data, not member data, so non-managers don't
      // need read access.
      match /wardCallingTemplates/{callingName} {
        allow read: if isManager(stakeId);
        allow write: if isManager(stakeId) && lastActorMatchesAuth(request.resource.data);
      }

      match /stakeCallingTemplates/{callingName} {
        allow read: if isManager(stakeId);
        allow write: if isManager(stakeId) && lastActorMatchesAuth(request.resource.data);
      }

      // ----- AuditLog -----
      // Manager-only read (the manager Audit Log page surfaces this).
      // Writes server-only — the parameterized `auditTrigger` Cloud
      // Function fans rows here via Admin SDK.
      match /auditLog/{auditId} {
        allow read: if isManager(stakeId);
        allow write: if false;
      }
    }
  }
}
