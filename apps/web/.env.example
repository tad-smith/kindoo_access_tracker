# Firebase web SDK config — Vite exposes only `VITE_*` vars to client code.
#
# Copy this file to one of these per-mode targets (all gitignored):
#   - apps/web/.env.staging      (loaded by `vite build --mode staging`)
#   - apps/web/.env.production   (loaded by `vite build`, default mode)
# Values come from the Firebase console after project bootstrap (B1 in
# the migration plan):
#   Console → Project settings → General → Your apps → Web → Config.
#
# Use the staging file for `kindoo-staging` values and the production
# file for `kindoo-prod` values. `deploy-staging.sh` invokes
# `build:staging`; `deploy-prod.sh` invokes the default `build`.
#
# `VITE_FIREBASE_PROJECT_ID` defaults to the staging project below.
# Override it in `.env.production`. Everything else is project-specific.
#
# In dev (`pnpm dev`), the Firestore SDK is pointed at the local emulator
# (apps/web/src/lib/firebase.ts), so the values here only affect prod
# builds; an empty staging file still lets `pnpm dev` boot.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=kindoo-staging
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=

# Set to `true` to force the production bundle to talk to the local
# Firestore emulator instead of real Firestore. Used by the Playwright
# webServer (e2e/playwright.config.ts) so the smoke test can boot the
# preview build without a real project. Leave unset for staging/prod
# deploys.
VITE_USE_FIRESTORE_EMULATOR=

# Set to `true` to force the production bundle to talk to the local
# Firebase Auth emulator instead of the real Auth service. Set by
# Playwright in CI/dev so the e2e suite can drive sign-in flows
# end-to-end against emulators. Leave unset for staging/prod deploys.
VITE_USE_AUTH_EMULATOR=

# FCM Web push public VAPID key. Generate via Firebase Console →
# Project Settings → Cloud Messaging → Web configuration → Generate
# key pair. Public-by-design (browsers receive it on subscribe). When
# unset, `getToken()` errors out and the Push Notifications panel
# surfaces a clear "VAPID key not configured" message instead of
# crashing. The Cloud Function trigger uses service-account auth and
# does NOT need the private half stored anywhere.
VITE_FCM_VAPID_PUBLIC_KEY=
