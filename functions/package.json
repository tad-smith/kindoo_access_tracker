{
  "name": "@kindoo/functions",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./lib/index.js",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "serve": "firebase emulators:start --only functions,firestore,auth",
    "shell": "firebase functions:shell",
    "test": "vitest run",
    "test:unit": "vitest run src/",
    "test:integration": "vitest run tests/",
    "test:integration:local": "firebase emulators:exec --only firestore,auth --project demo-kindoo-tests 'pnpm exec vitest run tests/'",
    "lint": "prettier --check src tests",
    "typecheck": "tsc -b tsconfig.tests.json"
  },
  "dependencies": {
    "firebase-admin": "^13.0.2",
    "firebase-functions": "^7.2.5"
  },
  "devDependencies": {
    "@kindoo/shared": "workspace:*",
    "@types/node": "^22.10.5",
    "esbuild": "^0.24.0",
    "firebase-functions-test": "^3.4.0",
    "vitest": "^2.1.8"
  }
}
