engine-strict=true
# pnpm 10 disables pre/post script hooks by default for non-npm-lifecycle
# names; we rely on `pretest` / `pretypecheck` / `prebuild` in apps/web/
# (and `pretypecheck` at the root) to regenerate `routeTree.gen.ts`
# before tsc / vitest runs in a fresh checkout. The generated file is
# gitignored — without this flag CI's `pnpm typecheck` would fail with
# missing-import errors.
enable-pre-post-scripts=true
